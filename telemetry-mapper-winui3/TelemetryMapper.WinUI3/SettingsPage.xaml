<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TelemetryMapper.WinUI3.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TelemetryMapper.WinUI3"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <Page.Resources>
        <DataTemplate
            x:Key="MapColorTemplate"
            x:DataType="local:MapColorDefinition">
            <toolkit:SettingsCard
                Description="{x:Bind Hex, Mode=OneWay}"
                Header="{x:Bind Label}"
                HorizontalAlignment="Stretch">
                <toolkit:SettingsCard.Content>
                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="8">
                        <Button
                            AutomationProperties.Name="{x:Bind ColorPickerAutomationName}"
                            Background="{x:Bind SwatchBrush, Mode=OneWay}"
                            Height="36"
                            Padding="0"
                            ToolTipService.ToolTip="Choose a color"
                            Width="52">
                            <Button.Resources>
                                <SolidColorBrush
                                    x:Key="ButtonBackgroundPointerOver"
                                    Color="{x:Bind Color, Mode=OneWay}" />
                                <SolidColorBrush
                                    x:Key="ButtonBackgroundPressed"
                                    Color="{x:Bind Color, Mode=OneWay}" />
                            </Button.Resources>
                            <Border
                                Background="{x:Bind SwatchBrush, Mode=OneWay}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch" />
                            <Button.Flyout>
                                <Flyout>
                                    <ColorPicker
                                        Color="{x:Bind Color, Mode=TwoWay}"
                                        IsAlphaEnabled="False"
                                        IsAlphaSliderVisible="False"
                                        IsAlphaTextInputVisible="False" />
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                        <Button
                            AutomationProperties.Name="{x:Bind ResetAutomationName}"
                            Click="OnResetColorClicked"
                            Content="Reset"
                            Tag="{x:Bind Key}"
                            ToolTipService.ToolTip="Restore the default color" />
                    </StackPanel>
                </toolkit:SettingsCard.Content>
            </toolkit:SettingsCard>
        </DataTemplate>
    </Page.Resources>

    <ScrollViewer
        HorizontalContentAlignment="Stretch"
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel
                Grid.Column="1"
                Margin="0,28,0,48"
                HorizontalAlignment="Stretch"
                Spacing="16">
                <TextBlock
                    AutomationProperties.HeadingLevel="Level1"
                    Style="{StaticResource TitleTextBlockStyle}"
                    Text="Settings" />

                <StackPanel Spacing="8">
                    <TextBlock
                        AutomationProperties.HeadingLevel="Level2"
                        Style="{StaticResource BodyStrongTextBlockStyle}"
                        Text="Appearance" />

                    <toolkit:SettingsCard
                        HorizontalAlignment="Stretch"
                        Description="Choose the color theme used throughout Telemetry Mapper."
                        Header="Theme">
                        <toolkit:SettingsCard.HeaderIcon>
                            <FontIcon Glyph="&#xE790;" />
                        </toolkit:SettingsCard.HeaderIcon>
                        <ComboBox
                            x:Name="ThemeComboBox"
                            AutomationProperties.Name="App theme"
                            SelectionChanged="OnThemeSelectionChanged">
                            <ComboBoxItem Content="Light" Tag="Light" />
                            <ComboBoxItem Content="Dark" Tag="Dark" />
                            <ComboBoxItem Content="Use system setting" Tag="Default" />
                        </ComboBox>
                    </toolkit:SettingsCard>
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock
                        AutomationProperties.HeadingLevel="Level2"
                        Style="{StaticResource BodyStrongTextBlockStyle}"
                        Text="Map colors" />
                    <toolkit:SettingsExpander
                        Header="Sectors"
                        HorizontalAlignment="Stretch"
                        IsExpanded="False"
                        ItemTemplate="{StaticResource MapColorTemplate}"
                        ItemsSource="{x:Bind MapColors.Sectors}" />

                    <toolkit:SettingsExpander
                        Header="Zones"
                        HorizontalAlignment="Stretch"
                        IsExpanded="False"
                        ItemTemplate="{StaticResource MapColorTemplate}"
                        ItemsSource="{x:Bind MapColors.Zones}" />

                    <toolkit:SettingsExpander
                        Header="Point Markers"
                        HorizontalAlignment="Stretch"
                        IsExpanded="False"
                        ItemTemplate="{StaticResource MapColorTemplate}"
                        ItemsSource="{x:Bind MapColors.Points}" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
