<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="TelemetryMapper.WinUI3.RecorderPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="using:TelemetryMapper.WinUI3.Controls"
      xmlns:converters="using:TelemetryMapper.WinUI3.Converters">
    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <Style x:Key="SurfaceStyle" TargetType="Border"><Setter Property="CornerRadius" Value="0" /><Setter Property="Background" Value="Transparent" /><Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" /><Setter Property="BorderThickness" Value="1" /></Style>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock"><Setter Property="FontSize" Value="14" /><Setter Property="FontWeight" Value="SemiBold" /></Style>
        <Style x:Key="CaptionStyle" TargetType="TextBlock"><Setter Property="FontSize" Value="12" /><Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" /><Setter Property="TextWrapping" Value="Wrap" /></Style>
    </Page.Resources>
    <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="395" /></Grid.ColumnDefinitions>
        <Border Grid.Column="0" BorderThickness="1,1,0,1" Style="{StaticResource SurfaceStyle}">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="48" /><RowDefinition Height="*" /><RowDefinition Height="56" /></Grid.RowDefinitions>
                <Grid Padding="16,0" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"><TextBlock VerticalAlignment="Center" Style="{StaticResource CaptionStyle}" Text="{x:Bind GameInfoText, Mode=OneWay}" TextTrimming="CharacterEllipsis" /></Grid>
                <controls:TrackMapCanvas x:Name="MapCanvas" Grid.Row="1" EmptyMessage="Start listening, then drive a session to draw the live map." />
                <Grid Grid.Row="2" Padding="12,8" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"><TextBlock VerticalAlignment="Center" Style="{StaticResource CaptionStyle}" Text="{x:Bind StatusText, Mode=OneWay}" TextTrimming="CharacterEllipsis" /></Grid>
            </Grid>
        </Border>
        <Border Grid.Column="1" BorderThickness="0,1,1,1" Style="{StaticResource SurfaceStyle}">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="48" /><RowDefinition Height="*" /><RowDefinition Height="56" /></Grid.RowDefinitions>
                <Grid Padding="16,0" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"><TextBlock VerticalAlignment="Center" Style="{StaticResource SectionTitleStyle}" Text="Map details" /></Grid>
                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Padding="16,12,16,20" Spacing="12">
                        <TextBlock Style="{StaticResource CaptionStyle}" Text="The first recorded lap is discarded. Enter these details before saving the final map." />
                        <TextBox x:Name="TrackNameBox" Header="Track name" PlaceholderText="e.g. Australian Grand Prix" />
                        <TextBox x:Name="CircuitNameBox" Header="Circuit name" PlaceholderText="e.g. Albert Park Circuit" />
                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="UDP connection" />
                        <NumberBox x:Name="UdpPortBox" Header="Listening port" Minimum="1" Maximum="65535" SmallChange="1" Value="20777" SpinButtonPlacementMode="Compact" />
                        <TextBlock Style="{StaticResource CaptionStyle}" Text="Listens on all local network interfaces. Change the port before starting the listener." />
                        <Rectangle Height="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Save locations" />
                        <Grid ColumnSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="FinalDirectoryBox" Header="Final JSON folder" IsReadOnly="True" PlaceholderText="Choose a folder"/><Button Grid.Column="1" VerticalAlignment="Bottom" Click="OnChooseFinalDirectoryClicked" Content="Choose" /></Grid>
                        <Grid ColumnSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="RawDirectoryBox" Header="Raw telemetry folder" IsReadOnly="True" PlaceholderText="Choose a folder"/><Button Grid.Column="1" VerticalAlignment="Bottom" Click="OnChooseRawDirectoryClicked" Content="Choose" /></Grid>
                    </StackPanel>
                </ScrollViewer>
                <Grid Grid.Row="2" Padding="12,8" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal" Spacing="8">
                        <Button Click="OnStartClicked" MinWidth="88"><StackPanel Orientation="Horizontal" Spacing="8"><FontIcon FontSize="14" Glyph="&#xE768;" /><TextBlock Text="Listen" /></StackPanel></Button>
                        <Button Click="OnStopClicked" MinWidth="80"><StackPanel Orientation="Horizontal" Spacing="8"><FontIcon FontSize="14" Glyph="&#xE71A;" /><TextBlock Text="Stop" /></StackPanel></Button>
                        <Button Click="OnSaveClicked" MinWidth="80" Style="{StaticResource AccentButtonStyle}"><StackPanel Orientation="Horizontal" Spacing="8"><FontIcon FontSize="14" Glyph="&#xE74E;" /><TextBlock Text="Save" /></StackPanel></Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
        <InfoBar x:Name="RecorderInfoBar" Grid.ColumnSpan="2" Margin="0,8,12,0" HorizontalAlignment="Right" VerticalAlignment="Top" IsClosable="True" IsOpen="False" />
    </Grid>
</Page>
